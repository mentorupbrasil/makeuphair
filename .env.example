# Copie para .env local ou configure na Vercel (Settings → Environment Variables)

# ─── Neon (PostgreSQL na nuvem) ───
# 1. Crie conta em https://neon.tech
# 2. Create Project → copie a connection string
# Use a URL com "-pooler" para a aplicação (serverless)
DATABASE_URL="postgresql://usuario:senha@ep-xxx-pooler.aws.neon.tech/neondb?sslmode=require"

# Opcional: URL direta para migrations locais (Prisma CLI deriva automaticamente da DATABASE_URL se omitida)
# DIRECT_URL="postgresql://usuario:senha@ep-xxx.aws.neon.tech/neondb?sslmode=require"

AUTH_SECRET="troque-por-uma-chave-segura-aleatoria"

# ─── Vercel Blob (upload de fotos/vídeos) ───
# Storage → Blob Store → Connect to Project
BLOB_READ_WRITE_TOKEN=""
BLOB_STORE_ID=""
BLOB_ACCESS="private"

# Após configurar Neon + deploy, rode seed uma vez:
# npm run db:seed
