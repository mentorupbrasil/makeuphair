# Copie para .env local ou configure no painel da Vercel (Settings → Environment Variables)

DATABASE_URL="file:./dev.db"
AUTH_SECRET="troque-por-uma-chave-segura-aleatoria"

# Obrigatório na Vercel para upload de fotos/vídeos
# Opção A (recomendada): Storage → seu Blob Store → Connect to Project
#   → a Vercel adiciona BLOB_READ_WRITE_TOKEN e BLOB_STORE_ID automaticamente
# Opção B: Storage → Blob → Settings → Create Read-Write Token
#   → cole manualmente como BLOB_READ_WRITE_TOKEN
BLOB_READ_WRITE_TOKEN=""
# Store privado (padrão Vercel) — uploads servidos via /api/media
# Use BLOB_ACCESS=public apenas se o store for público
BLOB_ACCESS="private"
